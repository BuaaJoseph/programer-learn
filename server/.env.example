# 鉴权后端环境变量示例。
# 用法：复制到「项目根目录」并命名为 .env（不是 server/.env）：
#   cp server/.env.example .env
# 之后 `npm run server` / `npm run server:dev` 会自动加载它（--env-file-if-exists=.env）。
# .env 已在 .gitignore 中，不会被提交。

# 服务端口
PORT=8787

# SQLite 数据库文件路径（默认 server/data/app.db）
# DB_PATH=server/data/app.db

# 验证码 HMAC 密钥（生产环境务必改成随机长字符串）
CODE_SECRET=change-me-to-a-long-random-string

# 邮件发送方式：mock（默认，仅打印、接口回显验证码） | smtp（真实发信）
EMAIL_PROVIDER=smtp

# ===== SMTP 配置（EMAIL_PROVIDER=smtp 时生效）=====
# SMTP_SECURE=true 表示用 SSL（端口 465）；false 表示 STARTTLS（端口 587）。
# SMTP_USER 是登录邮箱；SMTP_PASS 多数邮箱要用「授权码 / 应用专用密码」，不是邮箱登录密码。
# SMTP_FROM 是发件人显示名（不填则用 SMTP_USER）。

# 163 邮箱（默认示例）
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=you@163.com
SMTP_PASS=你的163授权码
SMTP_FROM=编程学习站 <you@163.com>

# QQ 邮箱
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=you@qq.com
# SMTP_PASS=你的QQ邮箱授权码
# SMTP_FROM=编程学习站 <you@qq.com>

# Gmail（需开启两步验证并生成「应用专用密码」）
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@gmail.com
# SMTP_PASS=应用专用密码

# 阿里云企业邮 / 自建：按服务商提供的 host/port 填写即可

# ===== 面试模拟：面试官模型接口（在此配置，不再由前端页面填写）=====
# 默认走 Anthropic Messages 协议，变量名与 Claude Code 对齐，可直接复用你的 Claude Code 配置：
ANTHROPIC_BASE_URL=http://www.dcc-aihub.shop
ANTHROPIC_AUTH_TOKEN=sk-你的密钥
# 模型名（按你的接口/中转支持的名字填，默认 gpt-5.5）
INTERVIEW_MODEL=gpt-5.5
# 协议风格：anthropic（默认）或 openai
# INTERVIEW_API_STYLE=anthropic
# Anthropic 版本头与单次最大输出 token（一般无需改）
# INTERVIEW_API_VERSION=2023-06-01
# INTERVIEW_MAX_TOKENS=2048
#
# 也可用 INTERVIEW_ 专用变量覆盖（优先级高于 ANTHROPIC_*）：
# INTERVIEW_BASE_URL=...
# INTERVIEW_AUTH_TOKEN=...
#
# 配置后可在「面试模拟」设置页点「测试连通性」，或：
#   curl -X POST http://localhost:8787/api/interview/ping

# ===== 面试模拟：自然语音 TTS（接近 ChatGPT 的人声）=====
# 走 OpenAI 兼容的 /v1/audio/speech。默认【自动复用上面的 ANTHROPIC_BASE_URL + ANTHROPIC_AUTH_TOKEN】，
# 若该中转一套 key 支持 OpenAI 全部接口（多数如此），则【无需任何额外配置即自动启用自然语音】。
# 只在需要单独指定 TTS 提供方/音色时才填以下项：
# INTERVIEW_TTS_BASE_URL=https://api.openai.com   # 单独的 TTS 服务（默认复用聊天 base）
# INTERVIEW_TTS_TOKEN=sk-...                       # 单独的 TTS 密钥（默认复用聊天 token）
# 默认 gpt-4o-mini-tts + 男声 onyx（最拟人）。中转若不支持 gpt-4o-mini-tts 就改成 tts-1 / tts-1-hd。
# INTERVIEW_TTS_MODEL=gpt-4o-mini-tts             # 或 tts-1 / tts-1-hd
# INTERVIEW_TTS_VOICE=onyx                        # 男声：onyx/echo/ash；女声：nova/shimmer/fable
# INTERVIEW_TTS_INSTRUCTIONS=...（仅 gpt-4o 系列生效，控制语气更像真人）
# INTERVIEW_TTS_FORMAT=mp3
# 若中转不支持语音接口、想强制用浏览器语音：INTERVIEW_TTS_DISABLED=1

# ===== 面试模拟：语音识别 STT（Whisper，让“听”也像 ChatGPT）=====
# 走 OpenAI 兼容的 /v1/audio/transcriptions，默认复用上面的 base + token，开箱即用。
# INTERVIEW_STT_MODEL=whisper-1
# INTERVIEW_STT_LANGUAGE=zh
# 想强制用浏览器原生识别：INTERVIEW_STT_DISABLED=1

# ===== 面试模拟：简历链接抓取 =====
# 设置页填「简历链接」时，后端会抓取该网页/PDF 并提取文字交给面试官。
# 默认禁止访问内网地址（防 SSRF）。若简历托管在内网/自建服务，需放行时设：
# INTERVIEW_FETCH_ALLOW_PRIVATE=1

# ===== 面试模拟：代码执行服务（Piston）=====
# 面试「编程考察」环节用 Piston 执行 Java / Python 代码。默认用公共实例 emkc.org，
# 生产建议自建（https://github.com/engineer-man/piston）并把地址填到 PISTON_URL。
# PISTON_URL=https://emkc.org/api/v2/piston/execute
# PISTON_PYTHON_VERSION=3.10.0
# PISTON_JAVA_VERSION=15.0.2
