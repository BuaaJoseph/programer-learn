# 鉴权后端环境变量示例。复制为项目根目录 .env 并按需修改。

# 服务端口
PORT=8787

# SQLite 数据库文件路径（默认 server/data/app.db）
# DB_PATH=server/data/app.db

# 验证码 HMAC 密钥（生产环境务必改成随机长字符串）
CODE_SECRET=change-me-to-a-long-random-string

# 邮件发送方式：mock（默认，仅打印） | smtp（真实发信）
EMAIL_PROVIDER=mock

# 当 EMAIL_PROVIDER=smtp 时需要以下 SMTP 配置（以 QQ 邮箱为例）
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=you@qq.com
# SMTP_PASS=your-smtp-authorization-code
# SMTP_FROM=你的名字 <you@qq.com>
